<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.description }}">
  <meta property="og:title" content="{{ title + ' — ' + site.title if title else site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <title>{% if title and title != "Home" %}{{ title }} — {% endif %}{{ site.title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20,400,1,0&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">

    <header class="site-header">
      <div class="site-nameplate">
        <a href="/">Rafael Nepô</a>
      </div>
      <nav class="main-nav">
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
        <a href="/training/">Training</a>
        <a href="/events/">Events</a>
        <a href="/apps/">Apps</a>
      </nav>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer>
      <p>© Rafael Nepô {{ site.year }} — Written by a human, published on the internet.</p>
    </footer>

  </div>
</body>
</html>
