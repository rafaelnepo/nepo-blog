  <!-- SPACING -->
  <h2>Spacing Scale</h2>
  <p>8px grid. All layout decisions use these tokens.</p>

  <div style="display: flex; flex-direction: column; gap: var(--space-xs); margin: var(--space-md) 0;">
    {% set spaces = [["xs","8px"],["sm","16px"],["md","24px"],["lg","32px"],["xl","48px"],["2xl","64px"]] %}
    {% for s in spaces %}
    <div style="display: flex; align-items: center; gap: var(--space-md);">
      <span style="font-size: var(--text-xs); color: var(--color-text-light); min-width: 80px; font-family: monospace;">--space-{{ s[0] }}</span>
      <span style="display: inline-block; height: 8px; width: {{ s[1] }}; background: var(--color-accent); border-radius: 1px;"></span>
      <span style="font-size: var(--text-xs); color: var(--color-text-light);">{{ s[1] }}</span>
    </div>
    {% endfor %}
  </div>

</div>
